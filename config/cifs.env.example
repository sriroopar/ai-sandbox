# Enable CIFS/SMB passthrough (Hyper-V Pro+, UTM, any host SMB share).
# Place this file at /etc/ai-sandbox/cifs.env (safe to commit this EXAMPLE; do not commit the live file or credentials).
USE_CIFS=1

# UNC path to a single host share containing config/, secrets/, workspace/ subdirs.
CIFS_URL=//172.19.96.1/ai-sandbox

# Credentials file (root:root, mode 600). Format:
#   username=<user>
#   password=<pass>
#   domain=<workgroup-or-hostname>
CIFS_CREDENTIALS=/etc/ai-sandbox/smbcredentials
