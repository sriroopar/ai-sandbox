# Enable SSHFS passthrough (Windows 11 Home via OpenSSH Server, or any SSH host).
# Place this file at /etc/ai-sandbox/sshfs.env (safe to commit this EXAMPLE; do not commit the live file).
USE_SSHFS=1

# Host reachable from the guest. For Hyper-V Default Switch this is typically 172.19.96.1
# (can change on host reboot — see config/ for static Internal vSwitch notes).
SSHFS_HOST=172.19.96.1

# Windows local profile (short) username — NOT the Microsoft-account email.
SSHFS_USER=CHANGEME

# Remote path relative to the SSH user's home dir. %USERPROFILE%\ai-sandbox => ai-sandbox
SSHFS_REMOTE_PATH=ai-sandbox

# Private key the guest uses to auth to the host. Public half must be in the host's
# administrators_authorized_keys (admin user) or ~/.ssh/authorized_keys (standard user).
SSHFS_IDENTITY=/home/ai/.ssh/id_ed25519
